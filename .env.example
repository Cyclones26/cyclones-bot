# Copy this file to ".env" for local testing (never commit the real ".env").
# On GitHub Actions, set these as repo secrets instead (Settings -> Secrets
# and variables -> Actions) -- do NOT put real values in this file.

X_API_KEY=YOUR_API_KEY_HERE
X_API_SECRET=YOUR_API_SECRET_HERE
X_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
X_ACCESS_SECRET=YOUR_ACCESS_TOKEN_SECRET_HERE
X_BEARER_TOKEN=YOUR_BEARER_TOKEN_HERE

MLB_TEAM_ID=509
PARENT_MLB_TEAM_ID=121
MLB_SEASON=2026

# Set to "true" while developing so scripts print tweets instead of posting.
DRY_RUN=true
